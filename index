<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BIO-FLUID ARCHITECT'S | Portfolio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <style>
        /* --- Color Palette & Variable Grading --- */
        :root {
            --bg-primary: #0d0d0d;        /* Deep Obsidian */
            --bg-secondary: #141414;      /* Charcoal Layer */
            --bg-light: #f9f8f6;          /* Gallery Cream */
            --accent-gold: #c5a880;       /* Champagne Gold */
            --accent-gold-hover: #e0c9a6; /* Radiant Highlight */
            --text-light: #ffffff;
            --text-dark: #222222;
            --text-muted: #888888;
            --transition-smooth: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

        /* --- Global Resets --- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        html {
            scroll-behavior: smooth;
            font-family: 'Montserrat', sans-serif;
            background-color: var(--bg-primary);
            color: var(--text-light);
            overflow-x: hidden;
        }
        h1, h2, h3, .brand-name {
            font-family: 'Cinzel', serif;
            letter-spacing: 2px;
        }
        a {
            text-decoration: none;
            color: inherit;
        }

        /* --- Custom Scrollbar --- */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: var(--bg-primary);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--accent-gold);
            border-radius: 4px;
        }

        /* --- Scroll Animation Classes --- */
        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: var(--transition-smooth);
        }
        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* --- Navigation Bar --- */
        header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            padding: 25px 5%;
            z-index: 1000;
            display: flex;
            justify-content: space-between;
            align-items: center;
            backdrop-filter: blur(10px);
            background: rgba(13, 13, 13, 0.75);
            border-bottom: 1px solid rgba(197, 168, 128, 0.1);
        }
        .logo-container {
            display: flex;
            flex-direction: column;
        }
        .brand-title {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--accent-gold);
        }
        .brand-subtitle {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 4px;
            color: var(--text-muted);
            margin-top: 2px;
        }
        nav ul {
            display: flex;
            list-style: none;
            gap: 35px;
        }
        nav ul li a {
            font-size: 0.85rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: var(--transition-smooth);
            position: relative;
            padding-bottom: 5px;
        }
        nav ul li a::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 1px;
            background-color: var(--accent-gold);
            transition: var(--transition-smooth);
        }
        nav ul li a:hover {
            color: var(--accent-gold);
        }
        nav ul li a:hover::after {
            width: 100%;
        }

        /* --- Hero Interactive Showcase --- */
        #hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            position: relative;
            padding: 0 20px;
            background: linear-gradient(135deg, #0d0d0d 0%, #1a1510 100%);
            overflow: hidden;
        }
        #hero::before {
            content: '';
            position: absolute;
            width: 300px;
            height: 300px;
            background: rgba(197, 168, 128, 0.05);
            border-radius: 50%;
            filter: blur(80px);
            top: 20%;
            left: 15%;
            animation: floatShape 8s infinite alternate ease-in-out;
        }
        .hero-content {
            z-index: 10;
            max-width: 900px;
        }
        .hero-tagline {
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 6px;
            color: var(--accent-gold);
            margin-bottom: 20px;
            opacity: 0;
            animation: fadeInDown 1s forwards 0.3s;
        }
        .hero-title {
            font-size: 3.5rem;
            font-weight: 700;
            line-height: 1.2;
            margin-bottom: 30px;
            opacity: 0;
            animation: fillIn 1.2s forwards 0.6s;
        }
        .hero-title span {
            color: transparent;
            -webkit-text-stroke: 1px var(--text-light);
        }
        .hero-desc {
            font-size: 1.05rem;
            font-weight: 300;
            color: #b3b3b3;
            margin-bottom: 40px;
            line-height: 1.8;
            opacity: 0;
            animation: fadeInUp 1s forwards 0.9s;
        }
        .cta-btn {
            display: inline-block;
            padding: 15px 35px;
            border: 1px solid var(--accent-gold);
            color: var(--accent-gold);
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 2px;
            font-weight: 600;
            border-radius: 0;
            transition: var(--transition-smooth);
            background: transparent;
            opacity: 0;
            animation: fadeInUp 1s forwards 1.2s;
        }
        .cta-btn:hover {
            background: var(--accent-gold);
            color: var(--bg-primary);
            box-shadow: 0 10px 30px rgba(197, 168, 128, 0.2);
            transform: translateY(-3px);
        }

        /* --- Global Sections Structural Setup --- */
        .section-padding {
            padding: 120px 8% 100px 8%;
        }
        .section-header {
            margin-bottom: 70px;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            border-bottom: 1px solid rgba(197, 168, 128, 0.15);
            padding-bottom: 20px;
        }
        .section-num {
            font-size: 3.5rem;
            font-weight: 700;
            color: rgba(197, 168, 128, 0.1);
            line-height: 1;
            font-family: 'Cinzel', serif;
        }
        .section-title h2 {
            font-size: 2rem;
            color: var(--text-light);
        }
        .section-title p {
            font-size: 0.8rem;
            text-transform: uppercase;
            color: var(--accent-gold);
            letter-spacing: 3px;
            margin-top: 5px;
        }

        /* --- Pillar Architecture Matrix (Services) --- */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 30px;
        }
        .service-card {
            background: var(--bg-secondary);
            border: 1px solid rgba(255, 255, 255, 0.03);
            padding: 40px 30px;
            transition: var(--transition-smooth);
            position: relative;
            overflow: hidden;
        }
        .service-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background: var(--accent-gold);
            transform: scaleX(0);
            transform-origin: left;
            transition: var(--transition-smooth);
        }
        .service-card:hover {
            transform: translateY(-10px);
            border-color: rgba(197, 168, 128, 0.2);
            background: #1a1a1a;
        }
        .service-card:hover::before {
            transform: scaleX(1);
        }
        .service-id {
            font-family: 'Cinzel', serif;
            font-size: 1.5rem;
            color: var(--accent-gold);
            margin-bottom: 25px;
            display: block;
        }
        .service-card h3 {
            font-size: 1.2rem;
            margin-bottom: 15px;
            font-weight: 600;
        }
        .service-card p {
            font-size: 0.85rem;
            color: var(--text-muted);
            line-height: 1.6;
        }

        /* --- Dynamic Portfolio Project Matrix --- */
        #portfolio-gallery {
            background-color: var(--bg-light);
            color: var(--text-dark);
        }
        #portfolio-gallery .section-title h2 {
            color: var(--text-dark);
        }
        .gallery-filter {
            display: flex;
            gap: 20px;
            margin-bottom: 50px;
            list-style: none;
        }
        .filter-item {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 600;
            cursor: pointer;
            padding: 8px 20px;
            border: 1px solid transparent;
            transition: var(--transition-smooth);
            color: var(--text-muted);
        }
        .filter-item.active, .filter-item:hover {
            border-color: var(--text-dark);
            color: var(--text-dark);
        }
        .portfolio-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 40px;
        }
        .project-card {
            background: white;
            border-radius: 0;
            overflow: hidden;
            box-shadow: 0 15px 40px rgba(0,0,0,0.05);
            transition: var(--transition-smooth);
            display: flex;
            flex-direction: column;
        }
        .project-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 25px 60px rgba(197, 168, 128, 0.15);
        }
        /* Color Grading Visual Placeholder Boxes */
        .project-visual-frame {
            height: 260px;
            position: relative;
            overflow: hidden;
            background: #e6e4df;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .project-visual-frame::after {
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            background: linear-gradient(to bottom, rgba(0,0,0,0) 50%, rgba(0,0,0,0.4) 100%);
            transition: var(--transition-smooth);
        }
        .project-card:hover .project-visual-frame::after {
            background: linear-gradient(to bottom, rgba(197,168,128,0.1) 0%, rgba(13,13,13,0.6) 100%);
        }
        /* Concrete Aesthetic Blueprints */
        .blueprint-vector {
            font-family: 'Cinzel', serif;
            font-size: 4rem;
            color: rgba(0, 0, 0, 0.04);
            user-select: none;
            text-transform: uppercase;
            font-weight: 700;
        }
        .project-meta {
            padding: 30px;
            border-top: 1px solid #f0edf6;
        }
        .project-category {
            font-size: 0.75rem;
            text-transform: uppercase;
            color: var(--accent-gold);
            letter-spacing: 2px;
            font-weight: 600;
            margin-bottom: 8px;
            display: block;
        }
        .project-title {
            font-size: 1.25rem;
            font-weight: 600;
            margin-bottom: 12px;
            color: var(--text-dark);
        }
        .project-desc {
            font-size: 0.88rem;
            color: #666;
            line-height: 1.6;
        }

        /* --- Footer & Core Communication Portal --- */
        footer {
            background: #080808;
            border-top: 1px solid rgba(197, 168, 128, 0.1);
            padding-top: 100px;
            padding-bottom: 40px;
        }
        .footer-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 60px;
            margin-bottom: 80px;
            padding: 0 8%;
        }
        .footer-brand-box p {
            font-size: 0.9rem;
            color: var(--text-muted);
            line-height: 1.8;
            margin-top: 20px;
        }
        .footer-header {
            font-size: 1.1rem;
            color: var(--text-light);
            margin-bottom: 25px;
            position: relative;
            padding-bottom: 10px;
        }
        .footer-header::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 30px;
            height: 1px;
            background: var(--accent-gold);
            border-radius: 2px;
        }
        .contact-link-item {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 20px;
            font-size: 0.95rem;
            color: #b3b3b3;
            transition: var(--transition-smooth);
        }
        .contact-link-item:hover {
            color: var(--accent-gold);
        }
        .contact-link-item .icon {
            color: var(--accent-gold);
            font-weight: 600;
        }
        .footer-bottom {
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            padding-top: 40px;
            text-align: center;
            font-size: 0.8rem;
            color: var(--text-muted);
            letter-spacing: 1px;
        }

        /* --- Keyframe Animations CSS Engine --- */
        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes fillIn {
            from { opacity: 0; letter-spacing: -2px; }
            to { opacity: 1; letter-spacing: 2px; }
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes floatShape {
            0% { transform: translateY(0) rotate(0deg); }
            100% { transform: translateY(-20px) rotate(10deg); }
        }

        /* --- Responsive Viewport Adaptation --- */
        @media (max-width: 768px) {
            .hero-title { font-size: 2.2rem; }
            nav { display: none; } /* Simplified for clean presentation layout */
            .section-header { flex-direction: column; align-items: flex-start; gap: 15px; }
            .gallery-filter { flex-wrap: wrap; gap: 10px; }
        }
    </style>
</head>
